<Application x:Class="OcAdvisor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">

    <Application.Resources>
        <!-- =========================
             Global Dark Theme Palette
             ========================= -->
        <Color x:Key="Bg0">#0F1115</Color>
        <Color x:Key="Bg1">#151922</Color>
        <Color x:Key="Bg2">#1C2230</Color>
        <Color x:Key="Stroke">#2A3346</Color>

        <Color x:Key="Text0">#E7EAF0</Color>
        <Color x:Key="Text1">#AEB6C6</Color>

        <Color x:Key="Accent">#4CC9F0</Color>
        <Color x:Key="Accent2">#4CC9F0</Color>

        <!-- Status colors (used by legend/risk text) -->
        <Color x:Key="Safe">#4CC9F0</Color>
        <Color x:Key="Aggressive">#7C5CFF</Color>
        <Color x:Key="Benchmark">#F72585</Color>

        <SolidColorBrush x:Key="BrushBg0" Color="{StaticResource Bg0}"/>
        <SolidColorBrush x:Key="BrushBg1" Color="{StaticResource Bg1}"/>
        <SolidColorBrush x:Key="BrushBg2" Color="{StaticResource Bg2}"/>
        <SolidColorBrush x:Key="BrushStroke" Color="{StaticResource Stroke}"/>

        <SolidColorBrush x:Key="BrushText0" Color="{StaticResource Text0}"/>
        <SolidColorBrush x:Key="BrushText1" Color="{StaticResource Text1}"/>

        <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="BrushAccent2" Color="{StaticResource Accent2}"/>

        <SolidColorBrush x:Key="BrushSafe" Color="{StaticResource Safe}"/>
        <SolidColorBrush x:Key="BrushAggressive" Color="{StaticResource Aggressive}"/>
        <SolidColorBrush x:Key="BrushBenchmark" Color="{StaticResource Benchmark}"/>

        <!-- =========================
             Prevent Windows Accent / purple selection leaks
             ========================= -->
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2A3346"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E7EAF0"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2A3346"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#E7EAF0"/>

        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1C2230"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E7EAF0"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#151922"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E7EAF0"/>
        <!-- ComboBox selection box + various templates pull from these. Override them so the collapsed selection box stays dark too. -->
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#1C2230"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#1C2230"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#0F1115"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#0F1115"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#AEB6C6"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#151922"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#E7EAF0"/>


        <!-- =========================
             Global Defaults
             ========================= -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BrushBg0}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText0}"/>
            <Setter Property="TextElement.Foreground" Value="{StaticResource BrushText0}"/>
        </Style>
<Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource BrushText1}"/>
        </Style>

        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
        </Style>

        <!-- =========================
             Inputs
             ========================= -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BrushBg2}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText0}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="CaretBrush" Value="{StaticResource BrushText0}"/>
            <Setter Property="Padding" Value="10,6"/>
        
            <Style.Triggers>
<Trigger Property="IsMouseOver" Value="True">
    <Setter Property="BorderBrush" Value="#3B4760"/>
</Trigger>
<Trigger Property="IsKeyboardFocused" Value="True">
    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
</Trigger>
            </Style.Triggers>
</Style>

        <!-- Selected (collapsed) ComboBox text in WPF can ignore ComboBox.Foreground
             if a global TextBlock style exists. We force the selection presenter to
             use the ToggleButton's Foreground via this template. -->
        <DataTemplate x:Key="ComboBoxSelectionTemplate">
            <TextBlock
                Text="{Binding}"
                Foreground="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"
                TextTrimming="CharacterEllipsis"/>
        </DataTemplate>

        <Style TargetType="ComboBox">
    <!-- Selection box (collapsed) -->
    <Setter Property="Background" Value="#EDEDED"/>
    <Setter Property="Foreground" Value="Black"/>
    <Setter Property="BorderBrush" Value="#2A3346"/>
    <Setter Property="Padding" Value="8,6"/>

            <Style.Triggers>
<Trigger Property="IsMouseOver" Value="True">
    <Setter Property="BorderBrush" Value="#3B4760"/>
</Trigger>
<Trigger Property="IsKeyboardFocused" Value="True">
    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
</Trigger>
<Trigger Property="IsDropDownOpen" Value="True">
    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
</Trigger>
            </Style.Triggers>
</Style>


        <Style TargetType="ComboBoxItem">
    <!-- Dropdown items -->
    <Setter Property="Foreground" Value="#E7EAF0"/>
    <Setter Property="Background" Value="#1C2230"/>
    <Setter Property="Padding" Value="6"/>
    <Style.Triggers>
        <Trigger Property="IsHighlighted" Value="True">
            <Setter Property="Background" Value="#2A3346"/>
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="#2A3346"/>
        </Trigger>
    </Style.Triggers>
</Style>


        <!-- =========================
             Lists / Selection
             ========================= -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource BrushBg1}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource BrushText0}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#232B3B"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3346"/>
                    <Setter Property="Foreground" Value="{StaticResource BrushText0}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- =========================
             Buttons
             ========================= -->
        <!-- Base button template: rounded, subtle hover/press. -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#232B3B"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText0}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A3346"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C2230"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.15"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
    <Setter TargetName="Bd" Property="Effect">
        <Setter.Value>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>
        </Setter.Value>
    </Setter>
</Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary: outline/dark. -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#232B3B"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
        </Style>

        <!-- Primary: accent fill. -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground" Value="#0F1115"/>
        </Style>

        <!-- Back-compat key used elsewhere. -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}"/>

        <!-- =========================
             Grouping
             ========================= -->
        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource BrushText0}"/>
            <Setter Property="Background" Value="{StaticResource BrushBg1}"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource BrushText0}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushStroke}"/>
        </Style>

        <!-- =========================
             CheckBox (keeps your readable labels)
             ========================= -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource BrushText0}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#7A7A90"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    
<!-- =========================
     ScrollBar (subtle, dark) — fixed direction + proper horizontal/vertical sizing
     ========================= -->
<Style TargetType="ScrollBar">
    <!-- Align flush to edges (prevents the track/thumb from looking "centered" in the reserved gutter) -->
    <Setter Property="HorizontalAlignment" Value="Right"/>
    <Setter Property="VerticalAlignment" Value="Stretch"/>

    <!-- Default sizing (vertical). Horizontal gets Height via triggers below. -->
    <Setter Property="Width" Value="10"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="ScrollBar">
                <Grid Background="Transparent" SnapsToDevicePixels="True">
                    <Track x:Name="PART_Track"
                           IsDirectionReversed="True"
                           Focusable="False">
                        <!-- These buttons are required so Track logic is correct (prevents inverted behavior). -->
                        <Track.DecreaseRepeatButton>
                            <RepeatButton x:Name="DecreaseButton" Command="ScrollBar.PageUpCommand"
                                          Focusable="False"
                                          IsTabStop="False"
                                          Opacity="0"/>
                        </Track.DecreaseRepeatButton>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton x:Name="IncreaseButton" Command="ScrollBar.PageDownCommand"
                                          Focusable="False"
                                          IsTabStop="False"
                                          Opacity="0"/>
                        </Track.IncreaseRepeatButton>

                        <Track.Thumb>
                            <Thumb x:Name="Thumb" Background="#2A3346">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Track.Thumb>
                    </Track>
                </Grid>

                <ControlTemplate.Triggers>
                    <!-- Horizontal scrollbar: use height instead of width and swap page commands -->
                    <Trigger Property="Orientation" Value="Horizontal">
                        <!-- Horizontal bars should stretch across the full bottom gutter -->
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="VerticalAlignment" Value="Bottom"/>
                        <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                        <Setter Property="Height" Value="10"/>
                        <Setter Property="Width" Value="Auto"/>
                        <Setter TargetName="DecreaseButton" Property="Command" Value="ScrollBar.PageLeftCommand"/>
                        <Setter TargetName="IncreaseButton" Property="Command" Value="ScrollBar.PageRightCommand"/>
                    </Trigger>

                    <!-- Hover/pressed thumb subtle feedback -->
                    <Trigger SourceName="Thumb" Property="IsMouseOver" Value="True">
                        <Setter TargetName="Thumb" Property="Background" Value="#3B4760"/>
                    </Trigger>
                    <Trigger SourceName="Thumb" Property="IsDragging" Value="True">
                        <Setter TargetName="Thumb" Property="Background" Value="{StaticResource BrushAccent}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<Style TargetType="Thumb">
    <Setter Property="OverridesDefaultStyle" Value="True"/>
    <Setter Property="MinHeight" Value="40"/>   <!-- Vertical size -->
    <Setter Property="MinWidth" Value="40"/>    <!-- Horizontal size -->
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="Thumb">
                <Border Background="#2A3346"
                        CornerRadius="6"
                        Margin="1"/>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

    </Application.Resources>

</Application>