#!/usr/bin/env bash
set -euo pipefail

msg_file="$1"

# Keep this list tight to avoid false positives.
blocked_patterns=(
  "Made-with:[[:space:]]*Cursor"
  "Made with Cursor"
  "Generated by Cursor"
  "Generated with Cursor"
  "AI-generated"
  "Generated by ChatGPT"
  "Generated with ChatGPT"
  "Generated by Copilot"
  "Generated with Copilot"
)

for pattern in "${blocked_patterns[@]}"; do
  if rg -n -i --pcre2 "$pattern" "$msg_file" >/dev/null; then
    echo "Commit message contains blocked AI fingerprint: $pattern" >&2
    echo "Please edit the commit message to remove generated-signature text." >&2
    exit 1
  fi
done
